# Environment variables consumed by hardhat.config.ts and deploy scripts.
#
# Secrets in this project are read through Hardhat's `vars` API
# (encrypted at ~/.hardhat/vars.json), NOT from a .env file. Set them with:
#
#     npx hardhat vars set PRIVATE_KEY
#     npx hardhat vars set ETHERSCAN_API_KEY
#
# This file lists the variables the project reads, so contributors know
# what to provision. Copy to `.env` only if you also load it manually.

# Deployer private key. Required for any `--network sepolia` command.
PRIVATE_KEY=

# Etherscan API key. Required for `hardhat verify` after a Sepolia deploy.
ETHERSCAN_API_KEY=

# Toggle gas-usage report when running tests. Read directly from process.env.
REPORT_GAS=false
